# Copia este fichero a .env y rellena con tus valores reales.
# Nunca subas .env al repositorio.

# Flask
FLASK_ENV=dev
SECRET_KEY=cambia-esta-clave-por-una-larga-y-aleatoria

# Base de datos MySQL
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/vetesia?charset=utf8mb4

# JWT
JWT_SECRET_KEY=otra-clave-distinta-larga-y-aleatoria

# Email (Gmail con contraseña de aplicación, o cualquier SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=app_password_de_gmail
[email protected]

# Stripe (modo test)
STRIPE_SECRET_KEY=sk_test_tuclave
STRIPE_PUBLISHABLE_KEY=pk_test_tuclave
STRIPE_WEBHOOK_SECRET=whsec_tuclave

# Subida de archivos
UPLOAD_FOLDER=/var/vetesia/uploads
INVOICE_FOLDER=/var/vetesia/invoices

# CORS (orígenes permitidos para el frontend)
CORS_ORIGINS=http://localhost:3000,http://localhost:5500
